# Frontend–backend integration
# Copy to .env and set when the API is on a different host/port.
# Leave unset for local dev: the Vite dev server proxies /api to localhost:8080.

# API (gateway) base URL. No trailing slash.
# - Dev (npm run dev): leave empty so requests go to same origin and Vite proxies /api → :8080.
# - Prod (dashboard on different host): set to gateway URL, e.g. http://localhost:8080
# VITE_SERVER_URL=

# Recipient app base URL for survey links (optional).
# VITE_RECIPIENT_URL=
